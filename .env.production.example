# Production environment template for Nómina.
# Copy this file to .env.production and fill in all placeholder values.
# NEVER commit .env.production to version control.

APP_NAME="Nómina"
APP_ENV=production
# Generate with: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://planilla.tu-dominio.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=nomina
DB_USERNAME=nomina
# Generate a strong password and use the same value in POSTGRES_PASSWORD below.
DB_PASSWORD=

# PostgreSQL container bootstrap (must match DB_* values).
POSTGRES_DB=nomina
POSTGRES_USER=nomina
POSTGRES_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

BACKUP_ENABLED=true

# Initial super admin credentials. Keep email safe and password strong.
SUPER_ADMIN_EMAIL=admin@nomina.test
SUPER_ADMIN_PASSWORD=

# Used by certbot for SSL certificate requests.
DOMAIN=planilla.tu-dominio.com
EMAIL=admin@tu-dominio.com
