<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true">
    <testsuites>
        <testsuite name="PostgreSQL">
            <directory>tests/PostgreSQL</directory>
        </testsuite>
    </testsuites>
    <php>
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="DB_CONNECTION" value="pgsql_testing" force="true"/>
        <env name="DB_URL" value="" force="true"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
        <server name="APP_ENV" value="testing"/>
        <server name="DB_CONNECTION" value="pgsql_testing"/>
        <server name="DB_URL" value=""/>
    </php>
</phpunit>
